# Stockvest Mobile App Environment Variables
# Replace localhost with your machine's local IP when testing on a physical device
# e.g. EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

EXPO_PUBLIC_API_URL=http://192.168.0.100:3000

# Supabase — get these from your Supabase project dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://ldnymqtfvaquioyjzleu.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxkbnltcXRmdmFxdWlveWp6bGV1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYzMjAzMDEsImV4cCI6MjA5MTg5NjMwMX0.N54HdpNJZsWgfY3LHuIMAaLm9ata5l-uqL_4W-wwfQc

# Sentry — get DSN from sentry.io → your project → Settings → Client Keys
# Leave blank to disable crash reporting during local development
EXPO_PUBLIC_SENTRY_DSN=

# Mixpanel — get token from mixpanel.com → your project → Settings
EXPO_PUBLIC_MIXPANEL_TOKEN=

# EAS Update channel (set automatically by EAS, but useful to override locally)
EXPO_PUBLIC_UPDATE_CHANNEL=development
