# Stockvest Mobile App — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.

# ─── Backend ─────────────────────────────────────────────────────────────────
# URL of the running Express backend.
# Use your machine's local IP (not localhost) when testing on a physical device.
# Example: http://192.168.1.100:3000
EXPO_PUBLIC_API_URL=http://192.168.x.x:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Dashboard → Settings → API → Project API keys → anon public
# This key is safe to expose to the client (Row Level Security controls access).
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
