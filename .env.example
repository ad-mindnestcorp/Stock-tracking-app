# Stockvest Mobile App — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# This file is used for LOCAL DEVELOPMENT ONLY.

# ─── Environment ─────────────────────────────────────────────────────────────
# Current environment: development, staging, or production
EXPO_PUBLIC_ENV=development

# ─── Backend ─────────────────────────────────────────────────────────────────
# URL of the running Express backend (development).
# Use your machine's local IP (not localhost) when testing on a physical device.
# Example: http://192.168.1.100:3000
EXPO_PUBLIC_API_URL=http://192.168.x.x:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Dashboard → Settings → API → Project API keys → anon public
# This key is safe to expose to the client (Row Level Security controls access).
# For local development, use your development Supabase project's anon key.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key-here

# ─── EAS Environments Configuration ───────────────────────────────────────────
# The following environment variables are automatically injected by EAS builds:
#
# DEVELOPMENT BUILD:
#   EXPO_PUBLIC_ENV=development
#   EXPO_PUBLIC_API_URL=http://localhost:3000
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=(injected from DEV_SUPABASE_ANON_KEY secret)
#
# STAGING/PREVIEW BUILD:
#   EXPO_PUBLIC_ENV=staging
#   EXPO_PUBLIC_API_URL=https://staging-api.yourapp.com
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=(injected from STAGING_SUPABASE_ANON_KEY secret)
#
# PRODUCTION BUILD:
#   EXPO_PUBLIC_ENV=production
#   EXPO_PUBLIC_API_URL=https://api.yourapp.com
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=(injected from PROD_SUPABASE_ANON_KEY secret)
