# Stockvest Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Same value as EXPO_PUBLIC_SUPABASE_URL in the frontend .env
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Dashboard → Settings → API → Project API keys → service_role
# WARNING: This key bypasses Row Level Security. Keep it server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stock Data APIs ──────────────────────────────────────────────────────────
# Primary: https://finnhub.io → Dashboard → API key
FINNHUB_API_KEY=your-finnhub-api-key-here

# Fallback: https://twelvedata.com → Dashboard → API key
TWELVE_DATA_API_KEY=your-twelve-data-api-key-here

# Used by /api/market/unusual-volume to rank stocks by intraday/prev-day
# volume ratio. Sign up at https://polygon.io for a free key.
# If left blank, /api/market/unusual-volume will return an empty array.
POLYGON_API_KEY=your-polygon-api-key-here

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Model used for sections that require web search (foundation, valuation, risks)
# Must support web_search_preview tool. Default: gpt-4o-mini
OPENAI_WEB_SEARCH_MODEL=gpt-4o-mini

# Model used for data-driven sections (technicals, verdict). Default: gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini

# Sampling temperature (0 = deterministic). Default: 0
OPENAI_TEMPERATURE=0

# Max output tokens per section call. Default: 2000
OPENAI_MAX_OUTPUT_TOKENS=2000

# Per-section timeout in milliseconds. Default: 45000
OPENAI_SECTION_TIMEOUT_MS=45000

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# Development only — UUID used when no x-user-id header is present.
# Remove or leave blank in production.
DEV_USER_ID=00000000-0000-0000-0000-000000000001
